#!/usr/bin/env bash

LOGFILE="./log.txt"

YELLOW='\033[1;43m'
NC='\033[0m' # No Color
RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'

DATE=$(date '+%Y-%m-%d-%H-%M-%S')

write_log() {
    local message="$1"
    local local_message="${DATE} $message"
    echo -e "${CYAN}${DATE} $message ${NC}"
    #echo "$local_message" >> "$LOGFILE"
}

write_error() {
    local message="$1"
    local local_message="${DATE} $message"
    echo -e "${RED}${DATE} $message ${NC}"
    #echo "$local_message" >> "$LOGFILE"
}

write_success() {
    local message="$1"
    local local_message="${DATE} $message"
    echo -e "${GREEN}${DATE} $message ${NC}"
    #echo "$local_message" >> "$LOGFILE"
}

write_note() {
    local message="$1"
    local local_message="${DATE} $message"
    echo -e "${YELLOW}${DATE} $message ${NC}"
    #echo "$local_message" >> "$LOGFILE"
}

#Aliases
alias ls='ls -laFh --color=auto'
alias alias-test='echo "Alias test successful!"'

alias enabled='systemctl list-unit-files --type=service --state=enabled'
alias timers='systemctl list-timers --all'
alias services='systemctl list-units --type=service --all'
alias status='systemctl status'

alias size='du -hs'
alias rm='rm -i'
alias less='less -R'

alias catjson='python3 -m json.tool'

#Networking
alias ips='ip -br -c a'
alias macs='ip -br -c l'
alias routes='ip -br -c r'

#Vim
alias vim='vim -u $HOME/imports/.vimrc'

#Tmux
TERM=xterm-256color
if [ -f /usr/bin/tmux ]; then
	tmux source-file $HOME/imports/.tmux.conf
fi

#Functions
cd() { builtin cd "$@" && ls; }

restart() { if sudo systemctl restart "$1"; then
                write_success "Process $1 restarted successfully"
            else
                write_error "Something went wrong restarting process $1"
            fi
             systemctl status "$1";
           }

#Scripts
alias ifdocker='sudo bash $HOME/dotfiles/docker-interfaces.sh'

#PS1
if [ "$EUID" -eq 0 ]; then
    PS1="\[\e[0;31m\][\u@\h:\w]\[\e[0m\]\$ "
else
    PS1="\[\e[0;32m\][\u\[\e[0;36m\]@\h\[\e[0;35m\]:\w]\[\e[0m\]\$ "
fi
